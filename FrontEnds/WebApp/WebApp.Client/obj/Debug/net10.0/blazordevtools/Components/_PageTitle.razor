<PageTitle>@Title</PageTitle>
<div class="pagetitle">
    <h1 @attributes="@InputAttributesHeader">@Title</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href=""><i class="bi bi-house-door"> </i></a></li>
            <li class="breadcrumb-item">@BreadcrumbMenuGroupName</li>
            <li class="breadcrumb-item active">@BreadcrumbMenuOptionName</li>
        </ol>
    </nav>

</div>

@code {

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public string BreadcrumbMenuGroupName { get; set; }

    [Parameter]
    public string BreadcrumbMenuOptionName { get; set; }


    [Parameter]
    public Dictionary<string, object> InputAttributesHeader { get; set; } 
}
