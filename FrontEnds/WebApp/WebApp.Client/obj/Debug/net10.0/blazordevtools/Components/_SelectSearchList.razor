@typeparam TValue
@inherits InputSelect<TValue>

<select id="@Id" class="select2 form-select form-select-sm @Css" aria-label="..." disabled="@((_IsDisabled) ? "disabled" : null)">

    @if (ShowDefaultOption)
    {
        <option @key="0" value="0" selected disabled="selected">
            Seleccione...
        </option>
    }
    @if (DataSource != null)
    {
        foreach (var item in DataSource)
        {
            if ((Value != null) && (SelectorId(item) == SelectorId(Value)))
            {
                <option @key="@item" value="@SelectorId(item)" selected="selected">
                    @((MarkupString)SelectorText(item))
                </option>
            }
            else
            {
                <option @key="@item" value="@SelectorId(item)">
                    @((MarkupString)SelectorText(item))
                </option>
            }
        }
    }

</select>