<div>
    @HeaderFragment

    @foreach (var job in Jobs)
    {
        <div @key="job">

            @LineFragment(job)

        </div>
    }
</div>
@code {


    [Parameter]
    public List<JobModelView> Jobs { get; set; }

    [Parameter]
    public RenderFragment HeaderFragment { get; set; }

    [Parameter]
    public RenderFragment<JobModelView> LineFragment { get; set; }

}
