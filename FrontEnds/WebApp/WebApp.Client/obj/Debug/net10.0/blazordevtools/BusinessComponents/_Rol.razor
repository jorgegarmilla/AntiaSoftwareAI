@using WebApp.Client.ModelView

<div class="card" style="background-color:#f6f9ff">
    <div class="card-body">
        <h5 class="card-title">Rol</h5>


        <div class="card" style="width:500px">
            <div class="card-body" style="background: bisque;">
                <input style="color: darkslateblue" @bind="nombre" @bind:after="OnNombreChanged" @ondblclick="ondblclick" @onbeforecut="onbeforecut" @oncut="oncut" @onbeforepaste="onbeforepaste" @onpaste="onpaste" />
                <p>Valor actual: @nombre</p>
                <p>@mensaje</p>
            </div>
        </div>

        <EditForm EditContext="_editContext" FormName="RolForm" OnValidSubmit="OnValidSubmit" OnInvalidSubmit="OnInvalidSubmit">
            <div class="row">
                <div class="col-md-6">
                    <div class="row mb-3">
                        <label for="inputText" class="col-sm-4 col-form-label">Nombre</label>
                        <div class="col-sm-8">
                            <InputText @bind-Value="@_rol.Nombre" class="form-control col-sm-4" placeholder="Introduzca el Nombre del Rol" maxlength="50"></InputText>
                        </div>
                         <ValidationMessage class="offset-sm-4 col-md-8 validation-message" For="@(() => _rol.Nombre)" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="row mb-3">
                        <label for="inputText" class="col-sm-4 col-form-label">Salario</label>
                        <div class="col-sm-8">
                            <_InputDoubleFormatted @bind-Value="@_rol.Salario" Class="form-control" ParsingErrorMessage="Introduzca un número válido" />
                        </div>
                         <ValidationMessage class="offset-sm-4 col-md-8 validation-message" style="width: 100%; margin-top: .25rem; font-size: .875em; color: #dc3545" For="@(() => _rol.Salario)" />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="row mb-3">
                        <label for="inputText" class="col-sm-4 col-form-label">Fecha De Alta</label>
                        <div class="col-sm-8">
                            <InputDate @bind-Value=@_rol.FechaDeAlta ParsingErrorMessage="Introduzca una fecha válida" class="form-control col-sm-4"></InputDate>
                        </div>
                        <ValidationMessage class="offset-sm-4 col-md-8 validation-message" style="width: 100%; margin-top: .25rem; font-size: .875em; color: #dc3545" For="@(() => _rol.FechaDeAlta)" />
                    </div>
                </div>

            </div>
            <button type="submit" class="btn btn-primary me-1">Guardar</button>
        </EditForm>
        <br />

        <button @onclick="GuardarFuera" class="btn btn-primary me-1">Guardar (fuera)</button>

        <br />
        <br />
        <div>
            @ChildContent
        </div>

        @if (_rol?.Nombre == "A")
        {
            <div>
                Ha elegido A !!
            </div>
        }

    </div>
</div>



@code {

    private EditContext _editContext;

    [Parameter]
    public RolView? _rol { get; set; } = null;

    [Parameter]
    public EventCallback<RolView> RoleCreated { get; set; }

    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Inject]
    public IDataService DataService { get; set; }


    [Parameter]
    public DateTime? FechaAlta  { get; set; }

    [Parameter]
    public EventCallback<DateTime?> FechaAltaChanged { get; set; }



    #region Initializing

    protected override void OnInitialized()
    {
        // no llamadas a APIs aquí
        _rol = new RolView();
        _editContext = new EditContext(_rol);
    }

    protected override async Task OnInitializedAsync()
    {
        //llamadas a APIs aquí
        List<RolView> roles = await DataService.ReturnRolesAsync();
    }

    #endregion

