        // se ejecuta despues de que el valor haya sido cambiado.
        // llamadas a APIs aquí si es necesario
        return base.OnParametersSetAsync();
    }

    #endregion

    #region Rendering

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // jsInterop: después de que los elementos del DOM esten presentes.

        if (firstRender)
        {

        }
