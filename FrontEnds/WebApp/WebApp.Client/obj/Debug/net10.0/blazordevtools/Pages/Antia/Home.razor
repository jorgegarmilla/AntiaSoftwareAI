@code {

    private string? ConnectionString;
    private bool CollapsedTecnicas = true;
    private bool CollapsedFormularioYControles = true;
    private bool CollapsedParaHacer = true;
    private bool CollapsedLibros = true;

    protected override void OnInitialized()
    {
        // Obtiene el valor directamente
        ConnectionString = Configuration.GetConnectionString("DefaultConnection");
    }


    private void NavigateTo_form(MouseEventArgs e)
    {
        double aa = e.PageY;

        int empleadoId = 123; 
        Navigation.NavigateTo($"/form/{empleadoId}");
    }

    private void NavigateTo_pagecomponenttree(MouseEventArgs e)
    {
        double aa = e.PageY;

        Navigation.NavigateTo($"/pagecomponenttree/");
    }

    private void NavigateTo_renderfragmentNonGeneric(MouseEventArgs e)
    {
        double aa = e.PageY;

        Navigation.NavigateTo($"/renderfragmentNonGeneric/");
    }

    private void NavigateTo_renderfragmentbasic(MouseEventArgs e)
    {
        double aa = e.PageY;

        Navigation.NavigateTo($"/renderfragmentbasic/");
    }


    private void NavigateTo_renderfragmentGeneric(MouseEventArgs e)
    {
        double aa = e.PageY;

        Navigation.NavigateTo($"/renderfragmentGeneric/");
    }

    protected override async Task OnInitializedAsync()
    {

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == true)
        {
            //await Task.Delay(1000);
        }
    }
}

