        </BbCardHeader><span data-blazordevtools-marker="close" data-blazordevtools-id="bdt7c57608d" style="display:none!important"></span>
        <span data-blazordevtools-marker="open" data-blazordevtools-id="bdt5c940ae8" data-blazordevtools-component="BbCardContent" data-blazordevtools-file="Pages/Showcase/Dialogs.razor" data-blazordevtools-nested="true" style="display:none!important"></span><BbCardContent>
            <span data-blazordevtools-marker="open" data-blazordevtools-id="bdt2e9a8771" data-blazordevtools-component="BbDialog" data-blazordevtools-file="Pages/Showcase/Dialogs.razor" data-blazordevtools-nested="true" style="display:none!important"></span><BbDialog @bind-Open="dialogOpen">
