                    <span data-blazordevtools-marker="open" data-blazordevtools-id="bdt3930b176" data-blazordevtools-component="BbButton" data-blazordevtools-file="Pages/Showcase/Dialogs.razor" data-blazordevtools-nested="true" style="display:none!important"></span><BbButton>Open Dialog</BbButton><span data-blazordevtools-marker="close" data-blazordevtools-id="bdt3930b176" style="display:none!important"></span>
