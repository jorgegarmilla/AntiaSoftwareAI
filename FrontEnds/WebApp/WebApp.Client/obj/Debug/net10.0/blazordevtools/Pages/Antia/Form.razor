@code {

    private string? selectedCountry;
    private record Country(string Code, string Name);
    private List<Country> countries = new()
    {
        new("us", "United States"),
        new("gb", "United Kingdom"),
        new("ca", "Canada"),
        new("au", "Australia"),
        new("de", "Germany"),
        new("fr", "France"),
        new("jp", "Japan"),
        new("br", "Brazil"),
        new("in", "India"),
        new("mx", "Mexico")
    };



    [Parameter] public int? EmpleadoId { get; set; }
    private EmpleadoView _empleado { get; set; }
    private EditContext _editContext;
    private ValidationMessageStore _messageStore;
    private _SelectSearchList<Provincia> _provinciasSelect;
    private bool _provinciasSelectIsDisabled = true;
    private bool IsSubmitted = false;

    protected override void OnInitialized()
    {
        OnRellenarEmpleado();

        _editContext = new EditContext(_empleado);
        _messageStore = new ValidationMessageStore(_editContext);
        _editContext.OnValidationRequested += HandleValidationRequested;
        _editContext.SetFieldCssClassProvider(new AntiaFieldClassProvider());

    }

    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _messageStore.Clear();

        if (_empleado!.Nombre == "Jorge" && _empleado!.Apellidos == "Garmilla")
            _messageStore.Add(new FieldIdentifier(_empleado, string.Empty), "No puede ser Jorge Garmilla porque soy yo");

        _editContext.NotifyValidationStateChanged();
    }

    private async Task OnValidSubmit()
    {
        Console.WriteLine("Form Submitted Successfully!");
        IsSubmitted = true;

        // if (await _fluentValidationValidator!.ValidateAsync())
        // {
        //     Console.WriteLine("Form Submitted Successfully!");
        // }
    }

    private async Task OnCleanEmpleadoAsync()
    {
        this.OnInitialized();
        // await _fluentValidationValidator!.ValidateAsync();
    }

    private async Task OnDeactivateEmpleadoAsync()
    {
        FieldIdentifier fieldIdentifier = new FieldIdentifier(_empleado, nameof(_empleado.FechaBaja));

        var isValidFechaBaja = _editContext.IsValid(fieldIdentifier);

        _messageStore.Clear();
        if (isValidFechaBaja == false)
            _messageStore.Add(new FieldIdentifier(_empleado, string.Empty), "No se puede desactivar si la fecha de baja es inválida.");

        _editContext.NotifyValidationStateChanged();
    }

    private void OnRellenarEmpleado(bool suppliedData = false)
    {

        if (suppliedData == false)
        {
            _empleado = new EmpleadoView()
            {
                Contrato = new ContratoView(),
                EmpresasList = dataService.ReturnEmpresas(),
                ComunidadesAutonomasList = dataService.ReturnComunidadAutonomas(),
                FechaAlta = DateTime.Now,
                ProvinciaSelected = null
            };

            _provinciasSelectIsDisabled = true;
        }
        else
        {
            _empleado.Nombre = "Ana";
            _empleado.Apellidos = "García López";
            _empleado.Email = "ana@opentext.com";
            _empleado.Password = "Password123!";
            _empleado.Genero = EnumGenero.Femenino;
            _empleado.Salario = 3500.50;
            _empleado.FechaAlta = DateTime.Now.AddDays(2);
            _empleado.FechaBaja = DateTime.Now.AddDays(3);
            _empleado.EmpresaSelected = DataServiceThisPage.ReturnEmpresas()[0];
            _empleado.ComunidadAutonomaSelected = DataServiceThisPage.ReturnComunidadAutonomas()[1];
            _empleado.ProvinciaSelected = DataServiceThisPage.ReturnProvincias().Where(x => x.ComunidadAutonomaId_INT == int.Parse(_empleado.ComunidadesAutonomasList[0].Id)).First();

            _provinciasSelectIsDisabled = false;
        }
    }
    
    private async Task OnComunidadAutonomaChangeAsync(string comunidadId)
    {
        _empleado.ProvinciasList = DataServiceThisPage.ReturnProvincias().Where(x => x.ComunidadAutonomaId_INT == int.Parse(comunidadId)).ToList();
        _empleado.ProvinciaSelected = _empleado.ProvinciasList.First();
        _provinciasSelectIsDisabled = false;

        _editContext.NotifyFieldChanged(new FieldIdentifier(_empleado, nameof(_empleado.ComunidadAutonomaSelected)));
        await InvokeAsync(StateHasChanged);// no parece necesario
    }

    public void Dispose()
    {
        if (_editContext is not null)
        {
            _editContext.OnValidationRequested -= HandleValidationRequested;
        }
    }

}

