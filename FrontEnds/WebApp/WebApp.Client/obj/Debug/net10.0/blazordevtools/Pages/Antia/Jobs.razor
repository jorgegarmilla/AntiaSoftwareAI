@code {

    [Inject]
    private IApiProxy ApiProxy { get; set; } = default!;

    [Inject]
    private ResultState ResultState { get; set; } = default!;

    private EditContext _editContext;
    private List<JobModelView> _jobModelViewList = new List<JobModelView>();
    private JobModelView _jobModelView = null;
    // private FluentValidationValidator? _fluentValidationValidator;

    protected override async Task OnInitializedAsync()
    {
        _jobModelView = new JobModelView();
        _editContext = new EditContext(_jobModelView);
        _jobModelViewList = await ApiProxy.GetJobs();

        ResultState.SetResult(_jobModelViewList.Count());
    }

    private async Task OnValidSubmit()
    {
        // if (await _fluentValidationValidator!.ValidateAsync())
        // {
            JobModelView newJob = new JobModelView
            {
                Description = _jobModelView.Description,
                Id = _jobModelViewList.Max(j => j.Id) + 1,
                Status = EJobStatus.Pending 
            };

            await ApiProxy.AddJob(newJob);
            _jobModelViewList.Add(newJob);
            ResultState.SetResult(_jobModelViewList.Count());

            Console.WriteLine("Form Submitted Successfully!");
        // }
    }

    private void SortList((int oldIndex, int newIndex) indices)
    {
        // deconstruct the tuple
        var (oldIndex, newIndex) = indices;

        var items = _jobModelViewList;
        var itemToMove = items[oldIndex];
        items.RemoveAt(oldIndex);

        if (newIndex < items.Count)
        {
            items.Insert(newIndex, itemToMove);
        }
        else
        {
            items.Add(itemToMove);
        }

        StateHasChanged();
    }




    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender == true)
        {
            //await Task.Delay(1000);
        }
    }
}

