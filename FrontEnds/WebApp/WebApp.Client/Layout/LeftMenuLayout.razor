<div class="container py-6">
    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar Navigation -->
        <aside class="lg:w-64 shrink-0">
           
            <nav class="sticky top-20 space-y-1">
                <h4 class="font-semibold mb-3">Antía</h4>


                <NavLink href="/antia/test" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    TEST
                </NavLink>

                <NavLink href="/antia/environment" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Environment and cascade parameter
                </NavLink>
                <NavLink href="/initializator" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Initializator (api call)
                </NavLink>
                <NavLink href="/initializatorTwo" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Initializator #2
                </NavLink>
                <NavLink href="/pagecomponenttree" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Page Component Tree
                </NavLink>
                <NavLink href="/renderfragmentbasic" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Render Fragment Basic
                </NavLink>
                <NavLink href="/renderfragmentNonGeneric" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Render Fragment Non Generic
                </NavLink>
                <NavLink href="/renderfragmentGeneric" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Render Fragment Generic
                </NavLink>
                <NavLink href="/cssPage" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    CSS Sample
                </NavLink>
                <NavLink href="/AttributeSplatting" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Attribute Splatting
                </NavLink>
                <NavLink href="/modal" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    initializator
                </NavLink>
                <NavLink href="/initializator" class="flex items-center gap-2 rounded-md px-3 py-2 text-sm hover:bg-accent" ActiveClass="bg-accent">
                    <LucideIcon Name="mouse-pointer-click" Size="16" />
                    Modal
                </NavLink>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 min-w-0">
            @Body
        </main>
    </div>
</div>