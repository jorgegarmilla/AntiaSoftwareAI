@inject NavigationManager NavigationManager
@implements IDisposable
@inherits AntiaComponentBase

<header class="sticky-top border-bottom bg-body shadow-sm">
    <div class="container-fluid px-3">
        <div class="d-flex align-items-center" style="height: 3.5rem;">

            <a href="/" class="logo-header d-flex align-items-center me-4 text-decoration-none">
               <span class="d-none d-lg-block"></span>
            </a>

            <div class="me-4 d-flex">
                <a href="/" class="me-3 d-flex align-items-center gap-2 text-decoration-none">
                    <img src="images/sputnik.png" alt="" style="padding-top:20px">
                    <span class="fw-bold">Antia App</span>
                </a>
            </div>

            <nav class="nav d-flex align-items-center gap-1 fs-6 fw-medium">
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-link px-2 text-body-secondary" ActiveClass="text-body fw-semibold">
                    Antia
                </NavLink>
                <NavLink href="/showcase/buttons" class="nav-link px-2 text-body-secondary" ActiveClass="text-body fw-semibold">
                    Showcase
                </NavLink>

                <div>

                <AuthorizeView>
                    <Authorized>
                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="nav-link" style="background-color:red">
                                <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        no deberías ver esto aquí
                    </NotAuthorized>
                </AuthorizeView>
                </div>
            </nav>

            <div class="d-flex flex-grow-1 align-items-center justify-content-end gap-2">
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="ToggleDarkMode">
                    @if (isDarkMode)
                    {
                        <LucideIcon Name="sun" Size="20" />
                    }
                    else
                    {
                        <LucideIcon Name="moon" Size="20" />
                    }
                </BbButton>
            </div>

        </div>
    </div>
</header>

@code {

    [Inject]
    private IJSRuntime JS { get; set; } = null!;

    private bool isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isDarkMode = await JS.InvokeAsync<bool>("isDarkModeEnabled");
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        await JS.InvokeVoidAsync("toggleDarkMode");
        isDarkMode = !isDarkMode;
    }





    [Parameter]
    public EventCallback NavigationHappened { get; set; }

    [Inject]
    private ResultState ResultState { get; set; } = default!;

    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        ResultState.OnChange += StateHasChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        NavigationHappened.InvokeAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        ResultState.OnChange -= StateHasChanged;
    }

}
