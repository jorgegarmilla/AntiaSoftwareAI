@inject NavigationManager NavigationManager
@implements IDisposable
@inherits AntiaComponentBase

<header class="sticky top-0 z-50 w-full border-b bg-background">
    <div class="container flex h-14 items-center">
        <div class="container flex h-14 items-center">
            
            <a href="/" class="logo-header d-flex align-items-center">
               
                <span class="d-none d-lg-block"></span>
            </a>


            <div class="mr-4 flex">
                <a href="/" class="mr-6 flex items-center space-x-2">
                    <img src="images/sputnik.png" alt="" style="padding-top:20px">
                    <span class="font-bold">Antia App</span>
                </a>
            </div>

            <nav class="flex items-center space-x-6 text-sm font-medium">
                <NavLink href="/" Match="NavLinkMatch.All" style="" class="transition-colors hover:text-foreground/80 text-foreground/60" ActiveClass="text-foreground">
                    Antia
                </NavLink>
                <NavLink href="/showcase/buttons" style="margin-left: 20px;" class="transition-colors hover:text-foreground/80 text-foreground/60" ActiveClass="text-foreground">
                    Showcase
                </NavLink>
            </nav>

            <div class="flex flex-1 items-center justify-end space-x-2">
                <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" @onclick="ToggleDarkMode">
                    @if (isDarkMode)
                    {
                        <LucideIcon Name="sun" Size="20" />
                    }
                    else
                    {
                        <LucideIcon Name="moon" Size="20" />
                    }
                </BbButton>

                <AuthorizeView>
                    <Authorized>
                        <BbPopover>
                            <BbPopoverTrigger>
                                <BbButton Variant="ButtonVariant.Ghost" Class="flex items-center gap-2 px-2">
                                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary text-primary-foreground text-sm font-semibold select-none">
                                        @GetUserInitials(context.User.Identity?.Name)
                                    </div>
                                    <span class="hidden sm:inline-block text-sm font-medium">
                                        @(context.User.Identity?.Name ?? context.User.FindFirst("email")?.Value ?? "Usuario")
                                    </span>
                                </BbButton>
                            </BbPopoverTrigger>
                            <BbPopoverContent Align="PopoverAlign.End" Class="w-48 p-1">
                                <form action="/Account/Logout" method="post">
                                    <input type="hidden" name="ReturnUrl" value="Account/Login" />
                                    <button type="submit" class="flex w-full items-center gap-2 rounded-sm px-2 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground cursor-pointer">
                                        <LucideIcon Name="log-out" Size="16" />
                                        Logout
                                    </button>
                                </form>
                            </BbPopoverContent>
                        </BbPopover>
                    </Authorized>
                </AuthorizeView>
            </div>

        </div>
    </div>
</header>

@code {

    [Inject]
    private IJSRuntime JS { get; set; } = null!;

    private bool isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isDarkMode = await JS.InvokeAsync<bool>("isDarkModeEnabled");
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        await JS.InvokeVoidAsync("toggleDarkMode");
        isDarkMode = !isDarkMode;
    }

    private static string GetUserInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}"
            : char.ToUpperInvariant(name[0]).ToString();
    }



    [Parameter]
    public EventCallback NavigationHappened { get; set; }

    [Inject]
    private ResultState ResultState { get; set; } = default!;

    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        ResultState.OnChange += StateHasChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        NavigationHappened.InvokeAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        ResultState.OnChange -= StateHasChanged;
    }

}
