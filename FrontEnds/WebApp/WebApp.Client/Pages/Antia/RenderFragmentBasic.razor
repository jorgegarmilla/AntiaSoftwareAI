@attribute [Authorize]
@page "/renderfragmentbasic"
@inherits AntiaComponentBase

<_PageTitle Title="Render Fragment Basic" BreadcrumbMenuGroupName="Template" BreadcrumbMenuOptionName="Render Fragment Basic"></_PageTitle>

@TextoHeader("Antía Garmilla Mancho")

@code {

    private RenderFragment<string>  TextoHeader => (nombre) => __builder =>
    {
        <h3>Hola desde Render Fragment, @nombre </h3>

        __builder.OpenElement(0, "h3");
        __builder.AddContent(1, "Adiós desde Render Fragment, ");
        __builder.AddContent(2, nombre);
        __builder.CloseElement();
    };

}
