@page "/antia/test"
@using System.Reflection
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inherits AntiaComponentBase
@attribute [Authorize]
@inject NavigationManager NavigationManager

@* <EditForm Model="@model" OnValidSubmit="HandleSubmit"> *@    
 <EditForm EditContext="editContext" OnValidSubmit="HandleSubmit">

    <DataAnnotationsValidator />
    <BbCard>
        <BbCardHeader>
            <BbCardTitle>Product Details</BbCardTitle>
            <BbCardDescription>Enter the product information.</BbCardDescription>
        </BbCardHeader>
        <BbCardContent class="space-y-4">
            <BbFormFieldInput TValue="string" Label="Product Name"
                              Placeholder="Enter name" @bind-Value="model.Name" />
            <BbFormFieldInput TValue="decimal?" Label="Price"
                              Format="N2" Placeholder="0.00"
                              @bind-Value="model.Price"
                              HelperText="Enter the retail price." />
            <BbFormFieldInput TValue="int" Label="Stock"
                              Placeholder="0" @bind-Value="model.Stock"
                              HelperText="Current inventory count." />
        </BbCardContent>
        <BbCardFooter>
            <BbButton Type="ButtonType.Submit" Class="w-full">Save</BbButton>
        </BbCardFooter>
    </BbCard>
</EditForm>

@code {

    private EditContext editContext = default!;


    private ProductModel model = new();

    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(model);
    }

    public async Task HandleSubmit()
    {
        
    }


    private class ProductModel
    {
        [Required(ErrorMessage = "Product name is required.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Price is required.")]
        public decimal? Price { get; set; } = 29.99m;

        [Range(1, 10000, ErrorMessage = "Stock must be between 1 and 10,000.")]
        public int Stock { get; set; }
    }
}